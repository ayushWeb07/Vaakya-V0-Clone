generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// project schema
model Project {
  id           String  @id @default(uuid())
  name         String
  thumbnailUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  RESULT
  ERROR
}

enum IS_MESSAGE_HELPFUL {
  DEFAULT
  HELPFUL
  NOT_HELPFUL
}

// message schema
model Message {
  id      String      @id @default(uuid())
  content String
  role    MessageRole
  type    MessageType

  fragment Fragment?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// fragment schema
model Fragment {
  id String @id @default(uuid())

  title        String
  sandboxUrl   String
  sandboxFiles Json

  isHelpful    IS_MESSAGE_HELPFUL @default(DEFAULT)
  creditsSpent Int                @default(0)
  workedFor    String             @default("")

  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
